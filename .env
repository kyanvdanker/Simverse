# ─── Simverse server config ───────────────────────────
# Copy this file to .env and fill in your values.
# Load with: node -r dotenv/config server.js
# Or just export each variable before running:
#   export GMAIL_USER=you@gmail.com && node server.js

# Port to listen on (default: 3000)
PORT=3000

# Secret path for the admin panel
# Visit: http://your-domain.com/{ADMIN_SECRET}
ADMIN_SECRET=simverse-admin-2025

# API key used by the admin dashboard — change to something random!
API_KEY=change-me-to-something-long-and-random

# ── Gmail email notifications ──────────────────────────
# Every contact form submission will be emailed to NOTIFY_TO.
#
# GMAIL_USER  : your Gmail address
# GMAIL_PASS  : a Gmail App Password (NOT your normal Gmail password)
#
# How to get a Gmail App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if not already on
#   3. Go to https://myaccount.google.com/apppasswords
#   4. App = "Mail", Device = "Other (Simverse)" → Generate
#   5. Copy the 16-character password shown and paste it below
#
GMAIL_USER=kyanvdanker@gmail.com
GMAIL_PASS=zsfb itqr fhkx ahky

# Where to deliver contact form emails (can be same as GMAIL_USER,
# or a different address entirely)
NOTIFY_TO=kyanvdanker@gmail.com
